{
  "name": "docs",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "if command -v codespell >/dev/null 2>&1; then cd .. && codespell; else echo 'codespell not found on PATH; skipping spellcheck (run `mise install` to enable it locally)'; fi",
    "build": "astro build && bun scripts/indexnow-ping.js",
    "preview": "astro preview",
    "astro": "astro",
    "test": "bun test",
    "spell": "cd .. && codespell",
    "spell:fix": "cd .. && codespell -w"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/node": "^11.0.0",
    "@astrojs/partytown": "^2.1.7",
    "@astrojs/sitemap": "3.7.3",
    "@astrojs/starlight": "0.41.3",
    "@astrojs/starlight-tailwind": "5.0.0",
    "@astrojs/vercel": "11.0.2",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "7.0.6",
    "astro-d2": "^0.13.0",
    "gray-matter": "^4.0.3",
    "hast-util-select": "^6.0.4",
    "rehype-parse": "^9.0.1",
    "rehype-remark": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-stringify": "^11.0.0",
    "starlight-links-validator": "^0.25.2",
    "starlight-llms-txt": "^0.11.0",
    "typescript": "^6.0.3",
    "unified": "^11.0.5",
    "unist-util-remove": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/hast": "^3.0.4"
  },
