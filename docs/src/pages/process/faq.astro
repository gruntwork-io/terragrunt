export const prerender = true;
---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { getCollection } from 'astro:content';
import { sortFaqEntries } from '@lib/faq';

const questions = sortFaqEntries(await getCollection('faq'));
---

<StarlightPage
  frontmatter={{
    title: 'Terragrunt Frequently Asked Questions',
    description: "We know there's a lot to learn about Terragrunt. Here are the frequently asked questions that users have asked and that you might find helpful!",
    tableOfContents: false,
  }}
>
  <p>We know there's a lot to learn about Terragrunt. Here are the frequently asked questions that users have asked and that you might find helpful!</p>

  {questions.length === 0 ? (
    <p><em>No frequently asked questions have been added yet.</em></p>
  ) : (
    <table class="faq-table">
      <thead>
        <tr>
          <th scope="col" class="faq-col-question">Question</th>
          <th scope="col" class="faq-col-answer">Answer</th>
        </tr>
      </thead>
      <tbody>
        {questions.map((entry) => (
          <tr>
            <td class="faq-question">
              <a href={`/process/faq/${entry.id}`}>{entry.data.question}</a>
            </td>
            <td>
              <span class="faq-answer-preview">{entry.data.description}</span>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  )}
</StarlightPage>

<style>
  .faq-table {
    width: 100%;
    table-layout: fixed;
  }

  .faq-col-question {
    width: 40%;
  }

  .faq-col-answer {
    width: 60%;
  }

  .faq-question a {
    font-weight: 600;
  }

  /* Show only the first two lines of the answer preview, with a trailing
     ellipsis when the text overflows. */
  .faq-answer-preview {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    color: var(--sl-color-gray-2);
  }

  /* On narrow viewports the answer preview adds little but horizontal
     crowding, so collapse to a single readable Question column. */
  @media (max-width: 50rem) {
    .faq-col-answer,
    .faq-table td:nth-child(2) {
      display: none;
    }
    .faq-col-question,
    .faq-table td:first-child {
      width: 100%;
    }
  }
</style>
